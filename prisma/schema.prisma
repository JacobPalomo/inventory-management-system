generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String
    role     Role   @default(VIEWER)

    shiftId     String?
    shift       Shift?       @relation(fields: [shiftId], references: [id])
    attendances Attendance[]

    movements Movement[]

    // Auditoría
    auditLogs AuditLog[]
    createdAt DateTime   @default(now())

    createdById  String?
    createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
    usersCreated User[]  @relation("UserCreatedBy")
}

model Shift {
    id        String  @id @default(uuid())
    name      String // Ej: "Turno Matutino"
    startTime Int // 0 - 1440
    endTime   Int
    isActive  Boolean @default(true)

    createdAt DateTime @default(now())

    users       User[]
    attendances Attendance[]
}

model Attendance {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    shiftId String?
    shift   Shift?  @relation(fields: [shiftId], references: [id])

    checkIn  DateTime
    checkOut DateTime?

    createdAt DateTime @default(now())
}

model Product {
    id          String     @id @default(uuid())
    name        String
    description String?
    stock       Int        @default(0)
    minStock    Int        @default(0)
    isActive    Boolean    @default(true)
    createdAt   DateTime   @default(now())
    movements   Movement[]
}

model Movement {
    id        String       @id @default(uuid())
    type      MovementType
    quantity  Int
    productId String
    userId    String
    createdAt DateTime     @default(now())

    product Product @relation(fields: [productId], references: [id])
    user    User    @relation(fields: [userId], references: [id])
}

enum Role {
    ADMIN
    EDITOR
    VIEWER
}

enum MovementType {
    IN
    OUT
}

enum AuditAction {
    CREATE
    UPDATE
    DELETE
    STOCK_ADJUST
    PRICE_CHANGE
}

enum EntityType {
    Auth
    Movement
    Product
    Shift
    User
    CashSession
    CashRegister
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
    id String @id @default(uuid())

    // Usuario que ejecutó la acción
    userId String

    // Tipo de acción
    action AuditAction

    // ID del registro afectado
    entityId String

    // Entidad afectada
    // Ej: "Product", "Sale", "Customer"
    entity EntityType

    // Valor antes del cambio
    oldValue Json?

    // Valor después del cambio
    newValue Json?

    // Fecha del evento
    createdAt DateTime @default(now())

    // Relación
    user User @relation(fields: [userId], references: [id])
}
