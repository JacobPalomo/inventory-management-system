generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum CashSessionStatus {
    OPEN
    CLOSED
}

enum SaleStatus {
    OPEN
    PAID
    CANCELLED
    REFUNDED
    HOLD
    QUOTE
}

enum SaleItemStatus {
    ACTIVE
    CANCELLED
    REFUNDED
}

model User {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String
    role     Role   @default(VIEWER)

    shiftId     String?
    shift       Shift?       @relation(fields: [shiftId], references: [id])
    attendances Attendance[]

    movements Movement[]

    // Auditoría
    auditLogs AuditLog[]
    createdAt DateTime   @default(now())

    createdById  String?
    createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
    usersCreated User[]  @relation("UserCreatedBy")

    // Relaciones POS
    cashSessions CashSession[]
    sales        Sale[]

    // Cancelaciones
    voidedSales        Sale[]        @relation("SaleVoidedBy")
    voidedSaleItems    SaleItem[]    @relation("SaleItemVoidedBy")
    cancelledSaleItems SaleItem[]    @relation("SaleItemCancelledBy")
    cancelledSales     Sale[]        @relation("SaleCancelledBy")
    closedSessions     CashSession[] @relation("CashClosedBy")
}

model Shift {
    id        String  @id @default(uuid())
    name      String // Ej: "Turno Matutino"
    startTime Int // 0 - 1440
    endTime   Int
    isActive  Boolean @default(true)

    createdAt DateTime @default(now())

    users       User[]
    attendances Attendance[]
}

model Attendance {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    shiftId String?
    shift   Shift?  @relation(fields: [shiftId], references: [id])

    checkIn  DateTime
    checkOut DateTime?

    createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
// CAJAS
//////////////////////////////////////////////////////

model CashRegister {
    id String @id @default(uuid())

    name        String
    description String?

    isActive Boolean @default(true)

    createdAt DateTime @default(now())

    sessions CashSession[]
}

//////////////////////////////////////////////////////
// SESIÓN CAJA
//////////////////////////////////////////////////////

model CashSession {
    id String @id @default(uuid())

    registerId String
    userId     String

    openingAmount  Float
    expectedAmount Float?
    countedAmount  Float?
    difference     Float?

    status CashSessionStatus @default(OPEN)

    openedAt DateTime  @default(now())
    closedAt DateTime?

    closedById String?
    closedBy   User?   @relation("CashClosedBy", fields: [closedById], references: [id])

    register CashRegister @relation(fields: [registerId], references: [id])
    user     User         @relation(fields: [userId], references: [id])

    sales Sale[]
}

//////////////////////////////////////////////////////
// SALES
//////////////////////////////////////////////////////

model Sale {
    id String @id @default(uuid())

    sessionId  String?
    userId     String
    customerId String?

    status SaleStatus @default(OPEN)

    subtotal Float
    tax      Float
    discount Float @default(0)
    total    Float

    notes String?

    isVoided Boolean @default(false)

    voidedAt   DateTime?
    voidedById String?
    voidedBy   User?     @relation("SaleVoidedBy", fields: [voidedById], references: [id])

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    cancelledAt DateTime?

    cancelledById String?
    cancelledBy   User?   @relation("SaleCancelledBy", fields: [cancelledById], references: [id])

    session CashSession? @relation(fields: [sessionId], references: [id])
    user    User         @relation(fields: [userId], references: [id])

    items SaleItem[]
}

model SaleItem {
    id String @id @default(uuid())

    saleId    String
    productId String

    quantity Float
    price    Float
    cost     Float?

    discount Float @default(0)

    subtotal Float
    tax      Float
    total    Float

    status SaleItemStatus @default(ACTIVE)

    // Cancelación parcial
    isVoided Boolean @default(false)

    voidedAt DateTime?

    voidedById String?
    voidedBy   User?   @relation("SaleItemVoidedBy", fields: [voidedById], references: [id])

    cancelledAt   DateTime?
    cancelledById String?
    cancelledBy   User?     @relation("SaleItemCancelledBy", fields: [cancelledById], references: [id])

    cancelReason String?

    sale    Sale    @relation(fields: [saleId], references: [id])
    product Product @relation(fields: [productId], references: [id])
}

model Product {
    id String @id @default(uuid())

    barcode String?
    sku     String?

    name        String
    description String?

    price   Float
    cost    Float?
    avgCost Float?

    stock         Float  @default(0)
    reservedStock Float  @default(0)
    minStock      Float  @default(0)
    maxStock      Float?

    taxRate Float @default(0)

    trackStock    Boolean @default(true)
    allowNegative Boolean @default(false)

    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    movements Movement[]

    saleItems SaleItem[]
}

model Movement {
    id String @id @default(uuid())

    productId String
    userId    String

    type     MovementType
    quantity Int
    cost     Float?
    reason   String?

    createdAt DateTime @default(now())

    product Product @relation(fields: [productId], references: [id])
    user    User    @relation(fields: [userId], references: [id])
}

enum Role {
    ADMIN
    EDITOR
    VIEWER
}

enum MovementType {
    IN
    OUT
}

enum AuditAction {
    CREATE
    UPDATE
    DELETE
    STOCK_ADJUST
    PRICE_CHANGE
}

enum EntityType {
    Auth
    Movement
    Product
    Shift
    User
    CashSession
    CashRegister
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
    id String @id @default(uuid())

    // Usuario que ejecutó la acción
    userId String

    // Tipo de acción
    action AuditAction

    // ID del registro afectado
    entityId String

    // Entidad afectada
    // Ej: "Product", "Sale", "Customer"
    entity EntityType

    // Valor antes del cambio
    oldValue Json?

    // Valor después del cambio
    newValue Json?

    // Fecha del evento
    createdAt DateTime @default(now())

    // Relación
    user User @relation(fields: [userId], references: [id])
}
